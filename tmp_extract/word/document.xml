crosoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh wp14"><w:body><w:p w14:paraId="36EEA5EA" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="001177AD"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr><w:t>KHẢO SÁT VÀ PHÂN TÍCH NGHIỆP VỤ</w:t></w:r></w:p><w:p w14:paraId="46525762" w14:textId="1F446AB6" w:rsidR="001177AD" w:rsidRPr="001177AD" w:rsidRDefault="001177AD" w:rsidP="001177AD"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="32"/><w:szCs w:val="32"/></w:rPr><w:t>WEBSITE QUẢN LÝ VẬT LIỆU XÂY DỰNG</w:t></w:r></w:p><w:p w14:paraId="2C440125" w14:textId="221C0143" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>1. Giới thiệu</w:t></w:r></w:p><w:p w14:paraId="47ECC3B5" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Trong quá trình phát triển kinh tế hiện nay, ngành kinh doanh vật liệu xây dựng đóng vai trò quan trọng trong việc phục vụ nhu cầu xây dựng nhà ở, công trình dân dụng và công nghiệp. Tuy nhiên, tại nhiều cửa hàng vật liệu xây dựng quy mô nhỏ và vừa, công tác quản lý bán hàng, quản lý kho và theo dõi doanh thu vẫn chủ yếu được thực hiện bằng phương pháp thủ công như ghi chép sổ sách hoặc sử dụng các file Excel rời rạc.</w:t></w:r></w:p><w:p w14:paraId="611CBEDF" w14:textId="56835AD5" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="002E2D75" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>Các p</w:t></w:r><w:r w:rsidR="00FF0E50" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>hương pháp quản lý thủ công này tuy đơn giản nhưng tồn tại nhiều hạn chế như dễ sai sót, khó kiểm soát số lượng vật liệu, tốn nhiều thời gian tổng hợp và không đáp ứng được nhu cầu mở rộng kinh doanh. Do đó, việc xây dựng website quản lý vật liệu xây dựng là cần thiết nhằm tin học hóa các nghiệp vụ, nâng cao hiệu quả quản lý và hỗ trợ hoạt động kinh doanh.</w:t></w:r></w:p><w:p w14:paraId="07FBCEA5" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>2. Khảo sát nghiệp vụ</w:t></w:r></w:p><w:p w14:paraId="62333B9F" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>2.1. Mục tiêu khảo sát</w:t></w:r></w:p><w:p w14:paraId="2B869864" w14:textId="77777777" w:rsidR="002E2D75" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Mục tiêu của quá trình khảo sát nghiệp vụ là tìm hiểu mô hình hoạt động thực tế của cửa hàng vật liệu xây dựng, từ đó nắm bắt được các nghiệp vụ chính đang được thực hiện trong quá trình kinh doanh. Thông qua việc khảo sát, đề tài tiến hành phân tích cách thức quản lý hiện tại, xác định những ưu điểm và đặc biệt là các hạn chế còn tồn tại trong phương pháp quản lý thủ công. </w:t></w:r></w:p><w:p w14:paraId="79CC5B5C" w14:textId="77777777" w:rsidR="002E2D75" w:rsidRPr="001177AD" w:rsidRDefault="002E2D75" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Kết quả khảo sát là cơ sở quan trọng để đề xuất giải pháp xây dựng hệ thống website quản lý vật liệu xây dựng phù hợp với nhu cầu thực tế, đảm bảo tính khả thi và hiệu quả khi triển khai.</w:t></w:r></w:p><w:p w14:paraId="0C098F9B" w14:textId="070F8776" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>2.2. Phạm vi và đối tượng khảo sát</w:t></w:r></w:p><w:p w14:paraId="0082C4CC" w14:textId="1C6C9C9B" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Do đề tài được thực hiện dưới hình thức đồ án cá nhân, phạm vi khảo sát được giới hạn trong một cửa hàng vật liệu xây dựng có quy mô nhỏ đến vừa. Các đối tượng tham gia khảo sát bao gồm chủ cửa hàng, nhân viên bán hàng và khách hàng. Trong đó, chủ cửa hàng đóng vai trò là người quản lý toàn bộ hoạt động kinh doanh</w:t></w:r><w:r w:rsidR="002E2D75" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>,</w:t></w:r><w:r w:rsidR="002E2D75" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> chịu trách nhiệm về nhập hàng, bán hàng và thống kê doanh thu.</w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> nhân viên bán hàng trực tiếp tiếp nhận </w:t></w:r><w:r w:rsidR="00216D4F" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve">yêu cầu mua hàng </w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>và xử lý các giao dịch bán vật liệu</w:t></w:r><w:r w:rsidR="00216D4F" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> với khách hàng.</w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="00216D4F" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>K</w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>hách hàng là đối tượng mua và đặt các loại vật liệu xây dựng tại cửa hàng.</w:t></w:r></w:p><w:p w14:paraId="33C47DA2" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>2.3. Phương pháp khảo sát</w:t></w:r></w:p><w:p w14:paraId="70A0233E" w14:textId="226C9DA7" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Để thu thập thông tin phục vụ cho quá trình phân tích nghiệp vụ, đề tài sử dụng nhiều phương pháp khảo sát khác nhau. Cụ thể, phương pháp phỏng vấn giả định được áp dụng đối với chủ cửa hàng và nhân viên bán hàng nhằm tìm hiểu quy trình làm việc và các vấn đề gặp phải trong thực tế. Bên cạnh đó, việc quan sát trực tiếp các quy trình như </w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t>bán hàng, nhập kho và quản lý kho cũng được thực hiện. Ngoài ra, các tài liệu liên quan như hóa đơn bán hàng, sổ kho và bảng theo dõi doanh thu cũng được thu thập để phục vụ cho việc phân tích.</w:t></w:r></w:p><w:p w14:paraId="4A74F2A1" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3. Mô tả nghiệp vụ hiện tại (AS-IS)</w:t></w:r></w:p><w:p w14:paraId="038CD858" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.1. Quy trình quản lý vật liệu xây dựng</w:t></w:r></w:p><w:p w14:paraId="36AFA852" w14:textId="6B2582F4" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Hiện nay, các loại vật liệu xây dựng như xi măng, cát, đá, gạch, thép… được quản lý chủ yếu bằng sổ sách hoặc các file Excel. Thông tin vật liệu bao gồm tên vật liệu, loại vật liệu, đơn vị tính và đơn giá. Khi có sự thay đổi về giá bán hoặc thông tin vật liệu, nhân viên phải cập nhật thủ công, dẫn đến nguy cơ sai sót. Việc tìm kiếm thông tin vật liệu gặp nhiều khó khăn khi số lượng mặt hàng ngày càng lớn và hệ thống không lưu trữ lịch sử thay đổi giá hoặc thông tin vật liệu.</w:t></w:r></w:p><w:p w14:paraId="0BD930CD" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.2. Quy trình bán hàng</w:t></w:r></w:p><w:p w14:paraId="63A735BD" w14:textId="1DA5F900" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Trong quy trình bán hàng, khách hàng có thể đến trực tiếp cửa hàng hoặc liên hệ qua điện thoại để mua vật liệu xây dựng. Nhân viên bán hàng tiếp nhận yêu cầu của khách và ghi thông tin đơn hàng ra giấy. Sau đó, nhân viên kiểm tra số lượng tồn kho bằng cách xem sổ kho hoặc hỏi trực tiếp người quản lý. Giá bán và hình thức thanh toán được thỏa thuận trực tiếp với khách hàng. Sau khi hoàn tất giao dịch, hóa đơn giấy được xuất cho khách hàng.</w:t></w:r></w:p><w:p w14:paraId="20C57BBD" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.3. Quy trình quản lý đơn hàng</w:t></w:r></w:p><w:p w14:paraId="5D719D99" w14:textId="3769F416" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Các đơn hàng hiện nay được lưu trữ chủ yếu dưới dạng hóa đơn giấy, không có hệ thống lưu trữ tập trung. Do đó, việc theo dõi tình trạng đơn hàng như đã thanh toán hay chưa, đã giao hàng hay chưa gặp nhiều khó khăn. Ngoài ra, mỗi đơn hàng không có mã định danh riêng để tra cứu nhanh, gây bất tiện trong quá trình tổng hợp đơn hàng theo ngày hoặc theo tháng. Việc lưu trữ thủ công cũng dễ dẫn đến tình trạng thất lạc hoặc nhầm lẫn hóa đơn.</w:t></w:r></w:p><w:p w14:paraId="6AB7E5A0" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.4. Quy trình quản lý kho vật liệu</w:t></w:r></w:p><w:p w14:paraId="5971FCBA" w14:textId="275B57FB" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Kho vật liệu xây dựng được quản lý thông qua sổ kho hoặc bảng tính Excel. Khi có hoạt động nhập kho hoặc xuất kho, nhân viên cập nhật số lượng vật liệu một cách thủ công. Hệ thống hiện tại không có chức năng cảnh báo khi vật liệu sắp hết hàng, gây khó khăn trong việc chủ động nhập thêm hàng. Việc kiểm kê kho được thực hiện bằng phương pháp đếm thủ công, trong khi dữ liệu tồn kho không được cập nhật theo thời gian thực, dễ xảy ra chênh lệch số liệu.</w:t></w:r></w:p><w:p w14:paraId="04F95719" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.5. Quy trình quản lý thông tin nhân viên</w:t></w:r></w:p><w:p w14:paraId="450B2F83" w14:textId="78CEBE5B" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">Thông tin nhân viên được lưu trữ bằng hồ sơ giấy hoặc các file riêng lẻ, chưa có hệ thống quản lý tập trung. Khi có nhân viên mới, chủ cửa hàng ghi chép thông tin và phân công công việc một cách thủ công. Hệ thống hiện tại chưa có cơ chế phân quyền rõ ràng </w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t>giữa quản lý và nhân viên, gây khó khăn trong việc kiểm soát quyền hạn và trách nhiệm. Việc tra cứu thông tin nhân viên và theo dõi quá trình làm việc cũng gặp nhiều hạn chế.</w:t></w:r></w:p><w:p w14:paraId="592A8E94" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.6. Quy trình thống kê – báo cáo</w:t></w:r></w:p><w:p w14:paraId="0A046B07" w14:textId="7D30A50D" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Công tác thống kê và báo cáo được thực hiện thủ công vào cuối ngày hoặc cuối tháng. Chủ cửa hàng phải tổng hợp doanh thu và số lượng vật liệu bán ra dựa trên các hóa đơn giấy và sổ sách ghi chép. Quá trình này tốn nhiều thời gian và công sức, đồng thời dễ xảy ra sai sót. Ngoài ra, hệ thống hiện tại không hỗ trợ các báo cáo chi tiết theo ngày, tháng hoặc theo từng loại vật liệu.</w:t></w:r></w:p><w:p w14:paraId="668A9427" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>3.7. Đánh giá hệ thống hiện tại</w:t></w:r></w:p><w:p w14:paraId="77EB1EA6" w14:textId="2752600F" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Từ kết quả khảo sát, có thể nhận thấy hệ thống quản lý hiện tại tồn tại nhiều hạn chế như quản lý thủ công gây sai sót dữ liệu, khó kiểm soát chính xác tồn kho, không hỗ trợ báo cáo tự động và tốn nhiều thời gian, nhân lực. Bên cạnh đó, phương pháp quản lý hiện tại cũng không đáp ứng được nhu cầu mở rộng và phát triển kinh doanh trong tương lai.</w:t></w:r></w:p><w:p w14:paraId="1203D14D" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>4. Phân tích nghiệp vụ</w:t></w:r></w:p><w:p w14:paraId="3781285A" w14:textId="2B4E4D5E" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve">4.1. Mục tiêu hệ thống mới </w:t></w:r></w:p><w:p w14:paraId="21AF333B" w14:textId="3CA6BF04" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Hệ thống website quản lý vật liệu xây dựng được xây dựng với mục tiêu tự động hóa các quy trình quản lý và bán hàng. Hệ thống cho phép quản lý tập trung thông tin vật liệu, kho và đơn hàng, đồng thời hỗ trợ tra cứu và thống kê dữ liệu một cách nhanh chóng và chính xác. Qua đó, hệ thống góp phần nâng cao hiệu quả quản lý, giảm thiểu sai sót và cải thiện hoạt động kinh doanh của cửa hàng.</w:t></w:r></w:p><w:p w14:paraId="594D223E" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>4.2. Xác định các tác nhân (Actor)</w:t></w:r></w:p><w:p w14:paraId="2B5DCDFB" w14:textId="75FACCD9" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Trong hệ thống website quản lý vật liệu xây dựng, các tác nhân chính bao gồm</w:t></w:r><w:r w:rsidR="005B2D36" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>:</w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t xml:space="preserve"> Admin, Nhân viên và Khách hàng. Admin là người quản lý toàn bộ hệ thống và chịu trách nhiệm điều hành các chức năng chính. Nhân viên là người thực hiện các nghiệp vụ bán hàng và xử lý đơn hàng. Khách hàng là đối tượng xem thông tin và đặt mua vật liệu xây dựng thông qua hệ thống.</w:t></w:r></w:p><w:p w14:paraId="48B3E96E" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>4.3. Phân tích chức năng hệ thống</w:t></w:r></w:p><w:p w14:paraId="390EF33C" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>Đối với Admin, hệ thống cung cấp các chức năng như quản lý danh mục vật liệu, quản lý thông tin vật liệu xây dựng, quản lý tài khoản nhân viên, quản lý kho và theo dõi các báo cáo về doanh thu cũng như tồn kho.</w:t></w:r></w:p><w:p w14:paraId="0D960936" w14:textId="48B12F61" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="005B2D36" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>Đối với N</w:t></w:r><w:r w:rsidR="00FF0E50" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>hân viên có thể đăng nhập hệ thống để lập và xử lý đơn hàng, cập nhật trạng thái đơn hàng và xuất hóa đơn cho khách hàng.</w:t></w:r></w:p><w:p w14:paraId="2D43A520" w14:textId="22EA9935" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="005B2D36" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t>Đối với K</w:t></w:r><w:r w:rsidR="00FF0E50" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>hách hàng có thể xem danh sách vật liệu, tìm kiếm vật liệu theo nhu cầu, đặt hàng và tra cứu thông tin đơn hàng đã thực hiện.</w:t></w:r></w:p><w:p w14:paraId="172292CC" w14:textId="77777777" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:b/><w:bCs/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>4.4. Biểu đồ nghiệp vụ</w:t></w:r></w:p><w:p w14:paraId="56B0BC3F" w14:textId="7ADFCEC1" w:rsidR="00FF0E50" w:rsidRPr="001177AD" w:rsidRDefault="00FF0E50" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr></w:pPr><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:lastRenderedPageBreak/><w:t>Để mô tả trực quan các nghiệp vụ của hệ thống, đề tài sử dụng các biểu đồ UML như Use Case Diagram nhằm thể hiện mối quan hệ giữa các tác nhân và chức năng của hệ thống; Activity Diagram để mô tả luồng xử lý nghiệp vụ</w:t></w:r><w:r w:rsidR="005B2D36" w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/><w:lang w:val="en-US"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="001177AD"><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme="majorHAnsi"/><w:sz w:val="26"/><w:szCs w:val="26"/></w:rPr><w:t>và Sequence Diagram (tùy chọn) để mô tả trình tự tương tác giữa các thành phần trong hệ thống.</w:t></w:r></w:p><w:p w14:paraId="34FBB572" w14:textId="6A11C56C" w:rsidR="001F1D1F" w:rsidRPr="001177AD" w:rsidRDefault="001F1D1F" w:rsidP="00FF0E50"><w:pPr><w:jc w:val="both"/><w:rPr><w:rFonts w:asciiTheme="majorHAnsi" w:hAnsiTheme="majorHAnsi" w:cstheme=